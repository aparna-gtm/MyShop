<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">
    <!-- Brand / Logo -->
    <a class="navbar-brand fw-bold text-white" href="/products">MyShop</a>

    <!-- Mobile Toggle Button -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
      aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Links and Right Side Icons/Buttons -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-center">
        <li class="nav-item">
          <a class="nav-link text-white" href="/products">Home</a>
        </li>
        <%if(currentUser && currentUser.role==='seller' ){%>
          <li class="nav-item">
            <a class="nav-link text-white" href="/product/new">New</a>
          </li>
          <%}%>

            <!-- Cart icon with badge -->
            <%if(currentUser){%>
              <li class="nav-item position-relative ms-3">
                <a class="nav-link p-0" href="/cart/cart" style="color: white;">
                  <i class="bi bi-cart-fill" style="font-size: 1.15rem;"></i>
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                    style="font-size: 0.55rem; padding: 0.25em 0.4em;">
                    <span>
                      <%= currentUser.cart ? currentUser.cart.length : 0 %>
                    </span>
                    <span class="visually-hidden">items in cart</span>
                  </span>
                </a>
              </li>


              <!-- Wishlist icon with badge -->
              <li class="nav-item position-relative ms-3">
                <a class="nav-link p-0" href="/wishlist" style="color: white;">
                  <i class="bi bi-suit-heart-fill" style="font-size: 1.15rem;"></i>
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                    style="font-size: 0.55rem; padding: 0.25em 0.4em;">
                    <%= currentUser.wishlist ? currentUser.wishlist.length : 0 %>
                      <span class="visually-hidden">items in wishlist</span>
                  </span>
                </a>
              </li>
              <%}%>

                <!-- Login / Signup Buttons -->
                <li class="nav-item d-flex ms-3">
                  <%if(!currentUser){%>
                    <a href="/login" class="btn btn-outline-light me-2">Login</a>
                    <%} else{%>
                      <span class=" text-white  me-2 px-3 py-2">Hello, <%=currentUser.username%>!</span>
                      <a href="/logout" class="btn btn-light text-dark">Log Out</a>
                      <%}%>


                </li>
      </ul>
    </div>
  </div>
</nav>