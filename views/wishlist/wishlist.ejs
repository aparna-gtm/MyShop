<% layout("layouts/boilerplate.ejs") %>
<%- include("../partials/navbar") %>
<%- include("../partials/flash") %>

<div class="container py-5">
  <h3 class="text-center mb-5 pt-5"><i class="bi bi-suit-heart-fill"></i> Your Wishlist</h3>

  <% if(user.wishlist.length === 0){ %>
    <div class="alert alert-info text-center">Your wishlist is empty.</div>
  <% } else { %>
    <div class="row g-3">
      <% user.wishlist.forEach(pro => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border rounded shadow-sm">
            <img src="<%= pro.image %>" class="card-img-top" alt="<%= pro.name %>"
                 style="height: 180px; object-fit: contain; background-color: #f9f9f9;">
            <div class="card-body d-flex flex-column">
              <h6 class="card-title mb-1"><%= pro.name %></h6>
              <p class="text-muted small mb-2"><%= pro.description %></p>
              <p class="text-success fw-semibold mb-2">Price: ₹ <%= pro.price %></p>

              <div class="mt-auto d-grid gap-2">
                <a href="/buy/<%= pro._id %>" class="btn btn-dark w-100 fw-medium">
                  <i class="bi bi-bag-check-fill"></i> Buy Product
                </a>

                <form action="/user/<%= pro._id %>/remove-wishlist" method="POST">
                  <button type="submit" class="btn btn-danger w-100 fw-medium">
                    <i class="bi bi-trash-fill"></i> Remove
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
