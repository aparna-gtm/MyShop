<% layout("layouts/boilerplate.ejs") %>
<%- include("../partials/navbar") %>
<%- include("../partials/flash") %>

<div class="container mt-5">
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    <% for(let product of products){ %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          
          <!-- Product Image -->
          <img src="<%= product.image %>" class="card-img-top p-3"
               style="height:250px; object-fit:contain; background-color:#fff;" alt="<%= product.name %>">

          <div class="card-body d-flex flex-column">

            <!-- Product Title -->
            <h6 class="card-title text-truncate" title="<%= product.name %>"><%= product.name %></h6>

            <!-- Price -->
            <p class="text-success fw-bold mb-2">₹<%= product.price %></p>

            <!-- Short Description -->
            <p class="card-text text-muted mb-3" style="flex-grow:1; overflow:hidden; text-overflow:ellipsis; max-height:50px;">
              <%= product.description %>
            </p>

            <!-- Buttons -->
            <a href="/product/<%= product._id %>" class="btn btn-primary btn-sm mb-2">View Product</a>
            <% if(currentUser && currentUser.role==='seller'){ %>
              <form action="/product/<%= product._id %>?_method=DELETE" method="POST">
                <button class="btn btn-outline-danger btn-sm w-100">Delete Product</button>
              </form>
            <% } %>
          </div>

          <!-- Wishlist Heart -->
          <% if(currentUser){ %>
            <form action="/user/<%= product._id %>/wishlist" method="POST" 
                  class="position-absolute top-0 end-0 m-2">
              <button type="submit" class="btn btn-light btn-sm rounded-circle shadow-sm p-2">
                <i class="bi bi-suit-heart-fill text-danger"></i>
              </button>
            </form>
          <% } %>

        </div>
      </div>
    <% } %>
  </div>
</div>
