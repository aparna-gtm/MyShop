<% layout("layouts/boilerPlate.ejs") %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="container py-5">
  <h3 class="text-center mb-5">Checkout</h3>

  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card border-success shadow-sm p-4 bg-light">
        <h5 class="fw-bold text-center mb-3">Total Amount: ₹ <%= totalAmount %></h5>
        <ul class="list-group mb-3">
          <% for (let pro of products) { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <%= pro.name %>
              <span class="fw-semibold text-success">₹ <%= pro.price %></span>
            </li>
          <% } %>
        </ul>

        <form action="/payment_gateway/payumoney" method="POST">
          <input type="hidden" name="amount" value="<%= totalAmount %>"/>
          <input type="hidden" name="phone" value="<%= user.phone || '9999999999' %>" />
          <input type="hidden" name="service_provider" value="payu_paisa"/>
          <input type="hidden" name="productinfo" value="<%= itemNames.join(', ') %>"/>
          <input type="hidden" name="firstname" value="<%= user.name || 'Customer' %>"/>
          <input type="hidden" name="email" value="<%= user.email || 'customer@example.com' %>"/>
          <button type="submit" class="btn btn-success w-100 fw-bold">Pay Now</button>
        </form>
      </div>
    </div>
  </div>
</div>
